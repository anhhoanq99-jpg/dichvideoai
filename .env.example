# ==== Dịch Video AI — mẫu cấu hình (copy thành .env và điền giá trị thật) ====
# ⚠️ KHÔNG commit file .env. Trước khi ra mắt: tạo key MỚI cho mọi dịch vụ.

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Hàng đợi (Upstash Redis, bắt buộc rediss:// TLS) ---
REDIS_URL=rediss://default:password@host:6379

# --- Auth (better-auth + Google OAuth) ---
# Sinh secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Google Console: thêm redirect URI <BETTER_AUTH_URL>/api/auth/callback/google
BETTER_AUTH_SECRET=replace-with-64-hex-chars
BETTER_AUTH_URL=http://localhost:3000            # prod: https://ten-mien-cua-ban
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# --- Lưu trữ file (Cloudflare R2) ---
# Nhớ đặt CORS cho bucket: AllowedOrigins = domain web, ExposeHeaders = ETag
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dichvideo-prod

# --- AI providers ---
GROQ_API_KEY=                                     # STT (Whisper) + dịch dự phòng khi Gemini hết hạn mức ngày
GEMINI_API_KEY=                                   # OCR + dịch + giọng cao cấp
# GEMINI_TTS_RPM=60                               # đặt khi key đã lên paid tier (free tier: 3)
# GEMINI_OCR_MODEL=gemini-2.5-flash
# GEMINI_TRANSLATE_MODEL=gemini-2.5-flash
# GROQ_TRANSLATE_MODEL=llama-3.3-70b-versatile    # model dịch miễn phí khi rơi về Groq
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
ELEVENLABS_API_KEY=                               # giọng Adam, Rachel... — free ~10 phút/tháng (elevenlabs.io)
GOOGLE_TTS_API_KEY=                               # 8 giọng Việt Google — free 1-4tr ký tự/tháng (console.cloud.google.com)

# --- Thanh toán (SePay) ---
SEPAY_WEBHOOK_KEY=                                # khóa tự đặt, khai báo trong webhook SePay
SEPAY_BANK=                                       # vd: BIDV, VCB... (hiện QR trang Nạp credits)
SEPAY_ACCOUNT=                                    # số tài khoản nhận tiền
SEPAY_ACCOUNT_NAME=                               # tên chủ tài khoản (hiện ở trang Nạp tiền)

# --- Worker ---
WORKER_HEALTH_PORT=8787
# Optional (Windows dev): thư mục chứa ffmpeg/ffprobe. Linux để trống, dùng PATH.
FFMPEG_DIR=
# Optional: đường dẫn yt-dlp cho tính năng nhập video từ link (winget install yt-dlp).
# Linux VPS: "apt install yt-dlp" rồi để trống (dùng PATH).
YTDLP_PATH=
# Optional: file cookies.txt (định dạng Netscape) cho nguồn cần cookie như Douyin.
# Xuất bằng tiện ích "Get cookies.txt LOCALLY" khi đang mở douyin.com.
YTDLP_COOKIES=
