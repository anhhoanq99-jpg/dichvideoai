# --- Database (docker-compose.dev.yml defaults) ---
DATABASE_URL=postgresql://dichvideo:dichvideo_dev@localhost:5432/dichvideo

# --- Redis (docker-compose.dev.yml defaults) ---
REDIS_URL=redis://:dichvideo_dev@localhost:6379

# --- better-auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-64-hex-chars
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudflare R2 (Phase 2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dichvideo-dev

# --- AI providers (Phase 2+) ---
GROQ_API_KEY=
GEMINI_API_KEY=

# --- Worker ---
WORKER_HEALTH_PORT=8787
